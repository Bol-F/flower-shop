# Django
# In production set this in the platform dashboard, not only in this file:
# DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — pick ONE of the two styles below.
#
# Style 1: a single URL (e.g. Supabase, Railway, Render):
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
#
# Style 2: individual variables (local PostgreSQL):
DB_NAME=flower_shop_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Needed in production when the admin is served over https on another domain:
# CSRF_TRUSTED_ORIGINS=https://your-backend.example.com

# Redis (used by Celery broker and Django Channels)
REDIS_URL=redis://127.0.0.1:6379/0

# Notification placeholders. Leave blank in local development; order
# notifications will be logged to the console instead of crashing.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Optional production media storage (choose one provider when implemented).
# CLOUDINARY_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# SUPABASE_STORAGE_BUCKET=
