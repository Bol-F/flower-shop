# Bloom & Petal backend environment example
# Copy this file to backend/.env for local development.
# Do not commit real secrets.

# Django
# In production, set this in the platform dashboard:
# DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=replace-with-a-local-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Use DATABASE_URL for Supabase/Render-style connection strings.
# Leave it blank when using the individual local PostgreSQL variables below.
DATABASE_URL=
DB_NAME=flower_shop_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS / CSRF
# CORS_ALLOWED_ORIGINS should contain frontend origins that may call the API.
# CSRF_TRUSTED_ORIGINS should contain trusted HTTPS backend/admin origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CSRF_TRUSTED_ORIGINS=

# Redis
# Used by Celery broker and Django Channels.
REDIS_URL=redis://127.0.0.1:6379/0

# JWT
# SimpleJWT token lifetimes are currently configured in config/settings/base.py.
# Add env-driven JWT settings in code before adding JWT variables here.

# Notifications
# Keep email and Telegram disabled locally unless credentials are available.
# The app still writes NotificationLog rows and logs safely in development.
NOTIFICATIONS_ENABLED=true
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=
TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Payments
# Keep PAYMENT_PROVIDER=test until official provider docs and credentials exist.
PAYMENT_PROVIDER=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# Optional catalog/media helpers
PEXELS_API_KEY=

# Optional production media/storage placeholders.
# These are placeholders only unless storage integration is implemented.
CLOUDINARY_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
SUPABASE_STORAGE_URL=
SUPABASE_STORAGE_BUCKET=
SUPABASE_STORAGE_SERVICE_KEY=
