# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — pick ONE of the two styles below.
#
# Style 1: a single URL (e.g. Supabase, Railway, Render):
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
#
# Style 2: individual variables (local PostgreSQL):
DB_NAME=flower_shop_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Needed in production when the admin is served over https on another domain:
# CSRF_TRUSTED_ORIGINS=https://your-backend.example.com

# Redis (used by Celery broker and Django Channels)
REDIS_URL=redis://127.0.0.1:6379/0
