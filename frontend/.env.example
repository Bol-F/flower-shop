NEXT_PUBLIC_API_URL=http://localhost:8000
# On Vercel, set this to the Render backend origin, for example:
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
# Optional: comma-separated hosts allowed to access Next dev resources over LAN.
# Example for phone testing: NEXT_ALLOWED_DEV_ORIGINS=192.168.0.105
NEXT_ALLOWED_DEV_ORIGINS=

# Optional analytics/monitoring keys can be added here later.
# NEXT_PUBLIC_SENTRY_DSN=
