# Bloom & Petal frontend environment example
# Copy this file to frontend/.env.local for local development.
# Only put public, browser-safe values in NEXT_PUBLIC_* variables.

# Django API origin.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional public display flag. The backend PAYMENT_PROVIDER remains the source
# of truth for checkout behavior and provider secrets must never be exposed here.
NEXT_PUBLIC_PAYMENT_PROVIDER=test

# Optional: comma-separated hosts allowed to access Next dev resources over LAN.
# Example for phone testing: NEXT_ALLOWED_DEV_ORIGINS=192.168.0.105
NEXT_ALLOWED_DEV_ORIGINS=

# Optional public analytics/monitoring keys can be added here later.
# NEXT_PUBLIC_SENTRY_DSN=
